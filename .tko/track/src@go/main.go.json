        {
            "label": "2026-04-07_17-01-34",
            "content": "package main\n\nimport (\n\t\"fmt\"\n\t\"math/rand\"\n)\n\nfunc randInt(min, max int) int {\n\treturn min + rand.Intn(max-min+1)\n}\n\nfunc tree(t *Pen, size float64) {\n\tif size < 15 {\n\t\treturn \n\t}\n\tdgr := 40.0\n\t\n\tt.Walk(size)\n\tt.Right(dgr)\n\n\ttree(t, size*2/3)\n\n\tt.Left(dgr)\n\n\tt.Up()\n\tt.Walk(-size)\n\tt.Down()\n\n\ttree(t, size*2/3)\n\n\tt.Left(dgr)\n}\n\nfunc main() {\n\tsize := 200.0\n\tpen := NewPen(500, 500)   // cria um canvas de 500 de largura por 500 de altura\n\tpen.SetRGB(255, 0, 0)     // muda a cor do pincel para vermelho\n\tpen.SetPosition(250, 500) // move o pincel para x 250, y 500\n\tpen.SetHeading(90)        // coloca o pincel apontando para cima\n\tpen.Down()\n\n\ttree(pen, size)\n\n\tpen.SavePNG(\"tree.png\")\n\tfmt.Println(\"PNG file created successfully.\")\n}",
            "lines": "46"
